# ─────────────────────────────────────────────────────────────
#  GeoSignal Bot — Variables de Entorno
#  Copia este archivo como .env y rellena tus valores reales
#  NUNCA subas el .env a GitHub (ya está en .gitignore)
# ─────────────────────────────────────────────────────────────

# ── OBLIGATORIAS ──────────────────────────────────────────────

# Token de tu bot de Telegram (obtenlo de @BotFather en Telegram)
TELEGRAM_TOKEN=tu_token_aqui

# API Key de Anthropic (Claude AI) → https://console.anthropic.com
ANTHROPIC_API_KEY=tu_anthropic_api_key_aqui

# ── OPCIONALES (mejoran la calidad de noticias) ───────────────

# NewsAPI → https://newsapi.org (plan gratuito: 100 req/día)
# Muy recomendada para noticias más frescas
NEWS_API_KEY=

# GNews → https://gnews.io (plan gratuito: 100 req/día)
# Alternativa a NewsAPI
GNEWS_API_KEY=

# ── SEGURIDAD ─────────────────────────────────────────────────
# IDs de Telegram que pueden usar el bot (separados por comas)
# Deja vacío para que cualquiera pueda usarlo
# Para obtener tu ID: habla con @userinfobot en Telegram
ALLOWED_CHAT_IDS=
